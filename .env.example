# =============================================================================
# Photo Classification Platform — environment template
# Copy to `.env` and adjust. `.env` is gitignored; never commit real secrets.
# =============================================================================

# ----- Host ports (deliberately uncommon to avoid clashing with other projects)
# Only the HOST side is unusual; containers keep standard ports internally.
WEB_HOST_PORT=47080
CLASSIFIER_HOST_PORT=47088
POSTGRES_HOST_PORT=47432
REDIS_HOST_PORT=47379
MINIO_API_HOST_PORT=47900
MINIO_CONSOLE_HOST_PORT=47901

# ----- Django / webapp
DJANGO_SECRET_KEY=dev-insecure-change-me-please-0123456789abcdef
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,webapp,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:47080,http://127.0.0.1:47080
DJANGO_LOG_LEVEL=INFO

# HTTPS enforcement — OFF for the local plain-HTTP compose demo.
# Set all of these to 1 in production (TLS terminated at the ingress).
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SECURE_HSTS_SECONDS=0

# Default admin auto-created on startup (demo convenience; disable in prod)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin12345

# ----- PostgreSQL
POSTGRES_DB=photoplatform
POSTGRES_USER=photo
POSTGRES_PASSWORD=photo-dev-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ----- Redis (Celery broker/result backend + cache)
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CACHE_URL=redis://redis:6379/2

# ----- MinIO / S3-compatible object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio-dev-password
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=photos
S3_REGION=us-east-1
# Public endpoint used to build signed URLs that a browser can reach
S3_PUBLIC_ENDPOINT_URL=http://localhost:47900
S3_SIGNED_URL_TTL=900

# ----- Classifier service
CLASSIFIER_URL=http://classifier:8000
CLASSIFIER_TIMEOUT=60

# ----- Classifier model config
# CLASSIFIER_STUB=1 -> deterministic dummy classifier (no torch/model download).
# CLASSIFIER_STUB=0 -> real Hugging Face models (downloaded on first start).
CLASSIFIER_STUB=0
# device: "auto" picks cuda when available else cpu. Force with "cuda" / "cpu".
MODEL_DEVICE=auto
# Hugging Face model ids (face-attribute analysis). Swap freely; contract is stable.
AGE_MODEL_ID=nateraw/vit-age-classifier
GENDER_MODEL_ID=rizvandwiki/gender-classification
HF_HOME=/models/.hf_cache
# Reject images whose NSFW score exceeds this threshold (0..1)
NSFW_THRESHOLD=0.85
NSFW_MODEL_ID=Falconsai/nsfw_image_detection

# ----- Upload safety limits
MAX_UPLOAD_BYTES=8388608          # 8 MiB
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/heic,image/avif
